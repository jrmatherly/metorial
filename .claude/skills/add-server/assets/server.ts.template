interface Config {
  token: string;
}

metorial.createServer<Config>(
  { name: 'SERVER_NAME', version: '1.0.0' },
  async (server, config) => {
    const BASE_URL = 'https://api.SERVICE_DOMAIN.com';

    // Helper function for API requests
    async function apiRequest(
      endpoint: string,
      method = 'GET',
      body?: unknown
    ): Promise<unknown> {
      const response = await fetch(`${BASE_URL}${endpoint}`, {
        method,
        headers: {
          Authorization: `Bearer ${config.token}`,
          'Content-Type': 'application/json'
        },
        body: body ? JSON.stringify(body) : undefined
      });

      if (!response.ok) {
        const error = await response.text();
        throw new Error(`API error ${response.status}: ${error}`);
      }

      return response.json();
    }

    // Example resource
    server.registerResource(
      'example-resource',
      new ResourceTemplate('service://resource/{id}', { list: undefined }),
      {
        title: 'Example Resource',
        description: 'Get a resource by ID'
      },
      async (uri, { id }) => ({
        contents: [
          {
            uri: uri.href,
            mimeType: 'application/json',
            text: JSON.stringify(await apiRequest(`/resource/${id}`), null, 2)
          }
        ]
      })
    );

    // Example tool: List items
    server.registerTool(
      'list_items',
      {
        title: 'List Items',
        description: 'List all items from the service',
        inputSchema: {
          limit: z
            .number()
            .optional()
            .default(10)
            .describe('Maximum number of items to return'),
          offset: z.number().optional().default(0).describe('Offset for pagination')
        }
      },
      async ({ limit, offset }) => {
        const items = await apiRequest(`/items?limit=${limit}&offset=${offset}`);
        return {
          content: [
            {
              type: 'text',
              text: JSON.stringify(items, null, 2)
            }
          ]
        };
      }
    );

    // Example tool: Get item
    server.registerTool(
      'get_item',
      {
        title: 'Get Item',
        description: 'Get a specific item by ID',
        inputSchema: {
          id: z.string().describe('Unique identifier of the item')
        }
      },
      async ({ id }) => {
        const item = await apiRequest(`/items/${id}`);
        return {
          content: [
            {
              type: 'text',
              text: JSON.stringify(item, null, 2)
            }
          ]
        };
      }
    );

    // Example tool: Create item
    server.registerTool(
      'create_item',
      {
        title: 'Create Item',
        description: 'Create a new item',
        inputSchema: {
          name: z.string().describe('Name of the item'),
          description: z.string().optional().describe('Optional description')
        }
      },
      async ({ name, description }) => {
        const item = await apiRequest('/items', 'POST', { name, description });
        return {
          content: [
            {
              type: 'text',
              text: `Created item: ${JSON.stringify(item, null, 2)}`
            }
          ]
        };
      }
    );
  }
);
